#!/bin/bash

# Symlink dotfiles only in Codespaces (locally they're managed by hand)
if [ -n "$CODESPACES" ]; then
    script_dir=$(dirname "$(readlink -f "$0")")
    files=$(find "$script_dir" -maxdepth 1 -type f -name ".*")
    for file in $files; do
        name=$(basename "$file")
        echo "Creating symlink to $name in home directory."
        rm -rf ~/"$name"
        ln -s "$file" ~/"$name"
    done
fi

# Install oh-my-zsh
sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended

# Install custom plugins
install_plugins() {
    script_dir=$(dirname "$(readlink -f "$0")")
    local plugin_dir="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins"
    mkdir -p "$plugin_dir"

    for plugin in wt pullall; do
        if [ -d "$script_dir/plugins/$plugin" ]; then
            rm -rf "$plugin_dir/$plugin"
            ln -s "$script_dir/plugins/$plugin" "$plugin_dir/$plugin"
            echo "Installed $plugin plugin."
        fi
    done
}

install_plugins

# Enable wt plugin in .zshrc if not already present
if grep -q '^plugins=(' ~/.zshrc 2>/dev/null; then
    for plugin in wt pullall; do
        if ! grep -q "plugins=.*\b${plugin}\b" ~/.zshrc; then
            sed -i.bak "s/^plugins=(\(.*\))/plugins=(\1 ${plugin})/" ~/.zshrc && rm -f ~/.zshrc.bak
            echo "Added ${plugin} to plugins in .zshrc."
        fi
    done
fi

# Change default shell to zsh if not already
if [ "$(basename "$SHELL")" != "zsh" ]; then
    sudo chsh -s "$(which zsh)" "$(whoami)"
fi
